{
  "name": "@sovrasdk/site-manifest",
  "version": "0.1.0",
  "description": "Parser and printer for Sovra site manifests with guaranteed round-trip.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wsprfme/sovra.git",
    "directory": "packages/site-manifest"
  },
  "homepage": "https://github.com/wsprfme/sovra/tree/main/packages/site-manifest",
  "bugs": "https://github.com/wsprfme/sovra/issues",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@sovrasdk/cid": "workspace:*",
    "@sovrasdk/contracts": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
