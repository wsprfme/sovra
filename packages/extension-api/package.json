{
  "name": "@sovrasdk/extension-api",
  "version": "0.1.0",
  "description": "The Sovra extension SDK: scoped DB, migrations, capabilities, routing, and lifecycle types.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wsprfme/sovra.git",
    "directory": "packages/extension-api"
  },
  "homepage": "https://github.com/wsprfme/sovra/tree/main/packages/extension-api",
  "bugs": "https://github.com/wsprfme/sovra/issues",
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["sovra", "self-hosted", "extension", "sdk", "plugin"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@sovrasdk/contracts": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
