{
	admin 127.0.0.1:2019
	on_demand_tls {
		ask http://127.0.0.1:8787/_tls/authorize
	}
}

# First-run / no-domain access: serve the dashboard over plain HTTP on the
# server's IP (or any hostname not otherwise matched). Once the wizard sets a
# primary domain, that hostname gets automatic HTTPS via the block below.
:80 {
	reverse_proxy 127.0.0.1:3000
}

# Primary dashboard domain (set SOVRA_PRIMARY_DOMAIN, then reload caddy).
{$SOVRA_PRIMARY_DOMAIN:localhost} {
	reverse_proxy 127.0.0.1:3000
}

# Catch-all for hosted custom domains. On-demand TLS is gated by the core
# `ask` endpoint so certificates are only issued for verified, active domains.
https:// {
	tls {
		on_demand
	}
	reverse_proxy 127.0.0.1:8787
}
