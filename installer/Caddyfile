{
	admin 127.0.0.1:2019
	on_demand_tls {
		ask http://127.0.0.1:8787/_tls/authorize
	}
}

# First-run / no-domain access: serve the dashboard over plain HTTP on the
# server's IP (or any hostname not otherwise matched). Once you set a primary
# domain in the dashboard, that hostname gets automatic HTTPS via the catch-all
# below (Caddy issues a cert on demand, gated by the core authorize endpoint).
:80 {
	reverse_proxy 127.0.0.1:3000
}

# Custom domains: the dashboard's primary domain and any hosted sites. On-demand
# TLS is gated by the core `ask` endpoint so certificates are only issued for
# domains Sovra has verified.
https:// {
	tls {
		on_demand
	}
	reverse_proxy 127.0.0.1:3000
}
